# ── Supabase (required) ──
# Service-role key — NOT the anon key. The agents write to all tables.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (required for injury/weather/power/public-splits agents) ──
ANTHROPIC_API_KEY=sk-ant-...
# Optional: comma-separated model-detection order. The system probes each on
# startup and uses the first your key can call. Default leads with the cheapest
# capable model to control cost: claude-haiku-4-5,claude-sonnet-4-6,claude-3-5-sonnet-20241022,claude-3-haiku-20240307
# Set a stronger model explicitly if you want it (and watch the bill):
# ANTHROPIC_MODELS=claude-sonnet-4-6,claude-haiku-4-5

# ── The Odds API (required for odds agent) ──
ODDS_API_KEY=...
# free = 500 req/mo, starter = 20k, pro = 5M. Controls the monthly request budget.
ODDS_API_TIER=free

# ── Alerts: SMS and/or Email (both optional; instant qualifying-play alerts) ──
# Twilio SMS (per-message cost + US A2P 10DLC registration):
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+15551234567
# ALERT_NUMBERS=+15557654321               # comma-separated recipients

# Email (FREE via Gmail or any SMTP — recommended). For Gmail: create an
# "App Password" (Google Account -> Security -> 2-Step Verification -> App passwords)
# and use it as SMTP_PASS. Host smtp.gmail.com, port 465.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=you@gmail.com                  # optional, defaults to SMTP_USER
# ALERT_EMAILS=you@gmail.com,partner@x.com # comma-separated recipients

# ── Server ──
PORT=8080
# Comma-separated origins allowed to call /health, /plays, /feed (CORS).
CORS_ORIGINS=https://blake27w.github.io

# ── Tuning (all optional) ──
# CONFIDENCE_FLOOR=70
# UNIT_DOLLARS=12
# DRY_RUN=false           # when true, agents compute but skip external writes/SMS

# Per-agent run interval in MINUTES (overrides the defaults). Raise the
# Claude-backed ones to cut cost. Defaults: injury 30, weather 45, power 60,
# public-splits 30, mlb-context 60, prop-engine 15, grading 30, clv 15;
# odds 5, sharp 2, schedule-spot 30, signal 5.
# INTERVAL_INJURY=30
# INTERVAL_WEATHER=45
# INTERVAL_POWER=60
# INTERVAL_PUBLIC_SPLITS=60
# INTERVAL_MLB_CONTEXT=60
# INTERVAL_GRADING=30
