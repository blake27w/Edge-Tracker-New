# ── Supabase (required) ──
# Service-role key — NOT the anon key. The agents write to all tables.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (required for injury/weather/power/public-splits agents) ──
ANTHROPIC_API_KEY=sk-ant-...
# Optional: comma-separated model-detection order. The system probes each on
# startup and uses the first your key can call. Defaults (modern → legacy):
#   claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5,claude-sonnet-4-20250514,claude-3-5-sonnet-20241022,claude-3-haiku-20240307
# ANTHROPIC_MODELS=claude-sonnet-4-6,claude-3-5-sonnet-20241022,claude-3-haiku-20240307

# ── The Odds API (required for odds agent) ──
ODDS_API_KEY=...
# free = 500 req/mo, starter = 20k, pro = 5M. Controls the monthly request budget.
ODDS_API_TIER=free

# ── Twilio SMS (optional — system runs fine without it) ──
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+15551234567
# Comma-separated subscriber numbers for alerts (overridden by `subscribers` table if present)
# ALERT_NUMBERS=+15557654321

# ── Server ──
PORT=8080
# Comma-separated origins allowed to call /health, /plays, /feed (CORS).
CORS_ORIGINS=https://blake27w.github.io

# ── Tuning (all optional) ──
# CONFIDENCE_FLOOR=70
# UNIT_DOLLARS=12
# DRY_RUN=false           # when true, agents compute but skip external writes/SMS
